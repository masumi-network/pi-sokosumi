{
  "name": "@masumi-network/pi-sokosumi",
  "version": "0.1.4",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Reusable Pi extension, Sokosumi coworker client, task poller, and Masumi completion-payment helpers.",
  "keywords": [
    "pi",
    "pi-extension",
    "sokosumi",
    "masumi",
    "agent",
    "coworker"
  ],
  "homepage": "https://github.com/masumi-network/pi-sokosumi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masumi-network/pi-sokosumi.git"
  },
  "bugs": {
    "url": "https://github.com/masumi-network/pi-sokosumi/issues"
  },
  "license": "UNLICENSED",
  "sideEffects": false,
  "files": [
    "dist/extensions",
    "dist/src",
    "docs",
    "skills",
    "prompts",
    "README.md",
    "TESTER_GUIDE.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/extensions/sokosumi/index.d.ts",
      "import": "./dist/extensions/sokosumi/index.js"
    },
    "./extension": {
      "types": "./dist/extensions/sokosumi/index.d.ts",
      "import": "./dist/extensions/sokosumi/index.js"
    },
    "./client": {
      "types": "./dist/src/client/httpSokosumiClient.d.ts",
      "import": "./dist/src/client/httpSokosumiClient.js"
    },
    "./types": {
      "types": "./dist/src/client/types.d.ts",
      "import": "./dist/src/client/types.js"
    },
    "./identity": {
      "types": "./dist/src/identity/resolveSokosumiIdentity.d.ts",
      "import": "./dist/src/identity/resolveSokosumiIdentity.js"
    },
    "./masumi": {
      "types": "./dist/src/masumi/index.d.ts",
      "import": "./dist/src/masumi/index.js"
    },
    "./poller": {
      "types": "./dist/src/poller/createSokosumiTaskPoller.d.ts",
      "import": "./dist/src/poller/createSokosumiTaskPoller.js"
    },
    "./worker": {
      "types": "./dist/src/worker/startSokosumiAgentWorker.d.ts",
      "import": "./dist/src/worker/startSokosumiAgentWorker.js"
    },
    "./mock-client": {
      "types": "./dist/src/client/mockSokosumiClient.d.ts",
      "import": "./dist/src/client/mockSokosumiClient.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm typecheck && pnpm test",
    "prepare": "tsc -p tsconfig.json",
    "test": "pnpm build && node --test dist/tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.75.5"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "pi": {
    "extensions": [
      "./dist/extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  }
}
